<!DOCTYPE html>
<html lang="en">
<head>
    
</head>
<body>
    <?php
function epostaGizle($ePosta){
    $sonuc = explode("@",$ePosta);
    $ilkKisim =substr($sonuc[0],0,3);
    $yildizli = str_repeat("*", strlen($sonuc[0])-3);
    return $ilkKisim . $yildizli . "@" . $sonuc[1];
  
}
epostaGizle("zihnikaya@aydin.edu.tr");
 ?>
</body>
</html>
